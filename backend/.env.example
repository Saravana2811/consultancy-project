# Server Configuration
PORT=5000
NODE_ENV=production
HOST=0.0.0.0

# Database (REQUIRED)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/
DB_NAME=textile

# JWT Configuration (REQUIRED FOR PRODUCTION)
# Generate a secure random string: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your_very_secure_random_jwt_secret_min_32_chars

# Session Configuration (REQUIRED FOR PRODUCTION)
SESSION_SECRET=your_very_secure_random_session_secret_min_32_chars

# Admin Configuration
ADMIN_CODE=your_secure_admin_registration_code

# Frontend Origins (comma-separated for multiple domains)
CLIENT_ORIGIN=https://yourdomain.com,https://www.yourdomain.com
BACKEND_URL=https://api.yourdomain.com

# Email Configuration (Gmail SMTP with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
FROM_EMAIL=your_email@gmail.com
MAILER_FALLBACK=ethereal

# Google OAuth Configuration
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Razorpay Payment Gateway
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
