# Admin Backend Server Configuration
PORT=5001
NODE_ENV=production
HOST=0.0.0.0

# Database (REQUIRED)
# Use either MONGO_URI or MONGODB_URI in this service
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/textile

# Security (REQUIRED)
JWT_SECRET=your_very_secure_random_jwt_secret_min_32_chars

# Admin Access Control
ADMIN_EMAIL=admin@yourdomain.com

# CORS
CLIENT_ORIGIN=https://admin.yourdomain.com

# Optional Email Settings (for OTP and notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_specific_password
FROM_EMAIL=your_email@gmail.com
