# Admin Front-end Environment Configuration
# Copy this file to .env.local and update values

# Admin app should call admin backend API
VITE_API_URL=https://prema-text-o3yp.onrender.com

# Client/main backend API (where chat + sample requests are stored)
VITE_CLIENT_API_URL=http://localhost:5000
VITE_CHAT_API_URL=http://localhost:5000

# URL of main client app (used for cross-app navigation)
VITE_MAIN_APP_URL=http://localhost:5173

# Production examples:
# VITE_API_URL=https://textile-admin-backend.onrender.com
# VITE_CLIENT_API_URL=https://textile-main-backend.onrender.com
# VITE_CHAT_API_URL=https://textile-main-backend.onrender.com
# VITE_MAIN_APP_URL=https://textile-client.onrender.com
