# Client Front-end Environment Configuration
# Copy this file to .env.local and update the values

# API Configuration
# For local development
VITE_API_URL=http://localhost:5000

# For production, update to your backend domain
# VITE_API_URL=https://api.yourdomain.com

# Admin App URL
VITE_ADMIN_APP_URL=http://localhost:5174

# For production, update to your admin app domain
# VITE_ADMIN_APP_URL=https://admin.yourdomain.com
